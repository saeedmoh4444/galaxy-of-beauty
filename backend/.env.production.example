# =============================================================================
# Galaxy of Beauty — Production Environment Variables
# =============================================================================
# Copy to .env and fill in production values.
# NEVER commit .env to version control.
# =============================================================================

# --- Server ---
NODE_ENV=production
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api
CORS_ORIGIN=https://galaxyofbeauty.sa,https://www.galaxyofbeauty.sa

# --- Database (PostgreSQL) ---
# Use connection pooling: ?connection_limit=20
DATABASE_URL="postgresql://user:password@your-rds-host:5432/Galaxy_of_Beauty_db?schema=public&connection_limit=20"
DIRECT_DATABASE_URL="postgresql://user:password@your-rds-host:5432/Galaxy_of_Beauty_db?schema=public"

# --- Redis (Upstash / ElastiCache) ---
REDIS_URL="rediss://user:password@your-redis-host:6379"
REDIS_PASSWORD=

# --- JWT Secrets (min 32 chars, generate with: openssl rand -hex 32) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- PayFort (Amazon Payment Services) - Production ---
PAYFORT_MERCHANT_ID=
PAYFORT_ACCESS_KEY=
PAYFORT_SHA_REQUEST_PHRASE=
PAYFORT_SHA_RESPONSE_PHRASE=
PAYFORT_SANDBOX=false
PAYFORT_CURRENCY=SAR

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Galaxy of Beauty <noreply@galaxyofbeauty.sa>"

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- AWS S3 (File Uploads) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-south-1
AWS_S3_BUCKET=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Sentry Error Tracking ---
SENTRY_DSN=

# --- ZATCA E-Invoicing (Phase 2) ---
ZATCA_CSID=
ZATCA_PRIVATE_KEY_PATH=

# --- Google Calendar OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Platform Configuration ---
PLATFORM_FEE_SAR=11.00
CASHBACK_FIRST_BOOKING_PERCENT=40
CASHBACK_SUBSEQUENT_PERCENT=5
WALLET_USAGE_MAX_PERCENT=10
TECHNICIAN_EARNINGS_PERCENT=99
TECHNICIAN_WALLET_SHARE_PERCENT=1
TECHNICIAN_PLATFORM_FEE_SHARE_PERCENT=25
MIN_WITHDRAWAL_BALANCE=200
MIN_WITHDRAWAL_AMOUNT=100
WITHDRAWAL_FEE_PERCENT=5
SUBSCRIPTION_BONUS=50
BOOKING_REQUEST_TIMEOUT_MIN=30
TERMS_VERSION=1.0

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_GENERAL=100
RATE_LIMIT_MAX_AUTH=20
RATE_LIMIT_MAX_ADMIN=200
