{
  "name": "galaxy-of-beauty-api",
  "version": "1.0.0",
  "description": "Galaxy of Beauty Platform - Backend API",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name",
    "prisma:push": "prisma db push",
    "prisma:seed": "node prisma/seed.js",
    "prisma:seed-demo": "node prisma/seed-demo.js",
    "prisma:studio": "prisma studio",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest --forceExit",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest tests/unit --forceExit",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest tests/integration --forceExit",
    "lint": "eslint src/ --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.7.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "http-errors": "^2.0.0",
    "i18next": "^23.11.0",
    "i18next-fs-backend": "^2.3.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mjml": "^4.15.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nanoid": "^5.0.7",
    "nodemailer": "^6.9.13",
    "openai": "^4.50.0",
    "qs": "^6.12.0",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.3",
    "prettier": "^3.3.0",
    "prisma": "^5.15.0",
    "supertest": "^7.0.0"
  }
}
