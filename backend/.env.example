# =============================================================================
# Galaxy of Beauty - Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# --- Server ---
NODE_ENV=development
PORT=4000
HOST=localhost
API_PREFIX=/api
CORS_ORIGIN=http://localhost:5173

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/Galaxy_of_Beauty_db?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=

# --- JWT ---
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- PayFort (Amazon Payment Services) ---
PAYFORT_MERCHANT_ID=your_merchant_id
PAYFORT_ACCESS_KEY=your_access_key
PAYFORT_SHA_REQUEST_PHRASE=your_request_phrase
PAYFORT_SHA_RESPONSE_PHRASE=your_response_phrase
PAYFORT_SANDBOX=true
PAYFORT_CURRENCY=SAR

# --- Email (Nodemailer) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@galaxyofbeauty.sa
SMTP_PASS=your_smtp_password
EMAIL_FROM="Galaxy of Beauty <noreply@galaxyofbeauty.sa>"

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+966XXXXXXXXX

# --- AWS S3 (File Uploads) ---
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=me-south-1
AWS_S3_BUCKET=galaxy-of-beauty-uploads

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# --- Sentry ---
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# --- ZATCA E-Invoicing ---
ZATCA_CSID=your_csid
ZATCA_PRIVATE_KEY_PATH=./certs/zatca-private.pem

# --- Platform Configuration ---
PLATFORM_FEE_SAR=11.00
PLATFORM_FEE_PERCENT=0
CASHBACK_FIRST_BOOKING_PERCENT=40
CASHBACK_SUBSEQUENT_PERCENT=5
WALLET_USAGE_MAX_PERCENT=10
TECHNICIAN_EARNINGS_PERCENT=99
TECHNICIAN_WALLET_SHARE_PERCENT=1
TECHNICIAN_PLATFORM_FEE_SHARE_PERCENT=25
MIN_WITHDRAWAL_BALANCE=200
MIN_WITHDRAWAL_AMOUNT=100
WITHDRAWAL_FEE_PERCENT=5
SUBSCRIPTION_BONUS=50
BOOKING_REQUEST_TIMEOUT_MIN=30

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_GENERAL=100
RATE_LIMIT_MAX_AUTH=20
RATE_LIMIT_MAX_ADMIN=200
