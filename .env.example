# =============================================================================
# Galaxy of Beauty — Environment Variables
# =============================================================================
# Copy to .env and fill in your values
# =============================================================================

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://gob_admin:gob_secure_pass@localhost:5432/Galaxy_of_Beauty_db?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars-long!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Next.js ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- OpenAI (AI Chatbot Layla + Skin Analysis) ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- Google Calendar (Technician Sync) ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- PayFort / Amazon Payment Services ---
PAYFORT_MERCHANT_ID=your_merchant_id
PAYFORT_ACCESS_KEY=your_access_key
PAYFORT_SHA_REQUEST_PHRASE=your_request_phrase
PAYFORT_SHA_RESPONSE_PHRASE=your_response_phrase
PAYFORT_SANDBOX=true

# --- Expo Push Notifications ---
EXPO_ACCESS_TOKEN=your-expo-access-token

# --- ZATCA E-Invoicing ---
ZATCA_VAT_NUMBER=300000000000003
ZATCA_API_URL=https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal
ZATCA_API_KEY=your-zatca-api-key
ZATCA_API_SECRET=your-zatca-api-secret

# --- SMS (Optional) ---
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=GalaxyBeauty

# --- Email (Nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Galaxy of Beauty <noreply@galaxyofbeauty.sa>"

# --- Sentry (Error Monitoring) ---
SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# --- Feature Flags ---
ENABLE_VIDEO_CONSULTATIONS=true
ENABLE_AI_SKIN_ANALYSIS=true
ENABLE_MARKETPLACE=true
ENABLE_SUBSCRIPTION_BOXES=true
