{
  "name": "@galaxy/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./prisma/schema.prisma"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf .turbo dist",
    "db:generate": "prisma generate",
