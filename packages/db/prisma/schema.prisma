// =============================================================================
// Galaxy of Beauty - Prisma Schema
// PostgreSQL 15+ | All models with indexes, JSONB localization, and relations
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  CUSTOMER
  TECHNICIAN
  ADMIN
}

enum BookingStatus {
  REQUESTED
  ACCEPTED
  PAYMENT_AUTHORIZED
  CONFIRMED_OFFLINE
  PAID
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
  VOIDED
}

enum PaymentIntent {
  AUTHORIZE
  CAPTURE
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_CUSTOMER
  RESOLVED_TECHNICIAN
  CLOSED
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CLAIMED
  EXPIRED
}

enum KYCStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionSource {
  CASHBACK
  PLATFORM_FEE_SHARE
  WITHDRAWAL
  SUBSCRIPTION_BONUS
  REFERRAL_BONUS
  CASH_HANDLING_FEE
  HANDLING_FEE_DEDUCTION
  REFUND
}

enum ZatcaStatus {
  PENDING
  REPORTED
  CLEARED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum AiFeature {
  CHATBOT
  RECOMMENDATIONS
  ONBOARDING_QUIZ
}

// =============================================================================
// Users & Authentication
// =============================================================================

model User {
  id                Int       @id @default(autoincrement())
  email             String    @unique
  phone             String    @unique
  phoneVerified     Boolean   @default(false)
  emailVerified     Boolean   @default(false)
  emailVerifyToken  String?
  emailVerifyExpiry DateTime?
  twoFactorSecret   String?
  twoFactorEnabled  Boolean  @default(false)
  passwordHash      String
  name              String
  role              UserRole  @default(CUSTOMER)
  isActive          Boolean   @default(true)
  suspendedAt       DateTime?
  suspendReason     String?
  avatarUrl         String?
  preferredLanguage String    @default("ar")
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  technician        Technician?
  wallet            Wallet?
  addresses         Address[]
  bookingsAsCustomer  Booking[]         @relation("CustomerBookings")
  bookingsAsTechnician Booking[]        @relation("TechnicianBookings")
  notifications     Notification[]
  reviews           Review[]           @relation("CustomerReviews")
  termsAcceptances  TermsAcceptance[]
  disputes          Dispute[]          @relation("DisputeRaisedBy")
  resolvedDisputes  Dispute[]          @relation("DisputeResolvedBy")
  waitlistEntries   WaitlistEntry[]
  refreshTokens     RefreshToken[]
  resetTokens       ResetToken[]
  pushTokens        PushToken[]
  loyaltyAccount    LoyaltyAccount?
  sentMessages      ChatMessage[]      @relation("SenderMessages")
  auditLogs         AuditLog[]
  wishlistItems     WishlistItem[]
  payouts           Payout[]
  streak            Streak?
  achievements      UserAchievement[]
  referralsMade     Referral[]         @relation("ReferralsMade")
  referralsReceived Referral[]         @relation("ReferralsReceived")

  @@index([role, isActive])
  @@index([phone])
  @@index([createdAt])
  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model ResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("reset_tokens")
}

model PushToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  platform  String   @default("ios") // ios | android | web
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("push_tokens")
}

model LoyaltyAccount {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  points        Int      @default(0)
  tier          String   @default("SILVER") // SILVER, GOLD, PLATINUM
  lifetimePoints Int     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  LoyaltyTransaction[]

  @@index([userId])
  @@index([tier])
  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id          Int      @id @default(autoincrement())
  accountId   Int
  points      Int      // Positive = earned, negative = redeemed
  reason      String   // "booking", "streak_bonus", "referral", "redemption", "tier_bonus"
  referenceId String?  // Booking ID, etc.
  createdAt   DateTime @default(now())

  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([createdAt])
  @@map("loyalty_transactions")
}

model LoyaltyReward {
  id            Int      @id @default(autoincrement())
  nameJson      Json     // { ar: "خصم ٢٠٪", en: "20% Discount" }
  descriptionJson Json   // { ar: "...", en: "..." }
  pointsCost    Int      // Points needed to redeem
  rewardType    String   // "discount_percent", "discount_fixed", "free_service"
  rewardValue   Decimal  @db.Decimal(10, 2) // e.g., 20 (%) or 50 (SAR)
  minTier       String   @default("SILVER") // Min tier required
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@map("loyalty_rewards")
}

// =============================================================================
// Technician Profile
// =============================================================================

model Technician {
  id                  Int       @id @default(autoincrement())
  userId              Int       @unique
  city                String
  area                String?
  bioJson             Json?     // { ar: "...", en: "..." }
  hourlyRate          Decimal   @default(0)
  ratingAvg           Decimal   @default(0)
  totalReviews        Int       @default(0)
  completedBookings   Int       @default(0)
  kycStatus           KYCStatus @default(PENDING)
  kycDocuments        Json?     // [{ type: "id_front", url: "..." }]
  kycNotes            String?
  suspendedAt         DateTime?
  googleCalendarToken String?
  googleCalendarEmail String?
  googleRefreshToken   String?
  googleTokenExpiry    DateTime?
  latitude             Float?
  longitude            Float?
  isEcoFriendly       Boolean  @default(false) // Uses cruelty-free/organic products
  bufferMinutes       Int      @default(15)    // Buffer between bookings
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilitySlots     AvailabilitySlot[]
  technicianServices    TechnicianService[]
  waitlistEntries       WaitlistEntry[]
  wishlistItems         WishlistItem[]

  @@index([city, kycStatus])
  @@index([ratingAvg])
  @@map("technicians")
}

// =============================================================================
// Wallet & Transactions
// =============================================================================

model Wallet {
  id           Int     @id @default(autoincrement())
  userId       Int     @unique
  balance      Decimal @default(0) @db.Decimal(10, 2) // Withdrawable balance
  bonusBalance Decimal @default(0) @db.Decimal(10, 2) // Non-withdrawable bonus
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          Int               @id @default(autoincrement())
  walletId    Int
  type        TransactionType
  source      TransactionSource
  amount      Decimal           @db.Decimal(10, 2)
  description String?
  referenceId String?           // Links to booking, payout, etc.
  idempotencyKey String?        @unique
  createdAt   DateTime          @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([referenceId])
  @@map("wallet_transactions")
}

// =============================================================================
// Addresses
// =============================================================================

model Address {
  id        Int      @id @default(autoincrement())
  userId    Int
  label     String   // e.g., "Home", "Work"
  city      String
  area      String
  street    String
  building  String?
  floor     String?
  apartment String?
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([userId])
  @@map("addresses")
}

// =============================================================================
// Service Catalog
// =============================================================================

model Category {
  id        Int    @id @default(autoincrement())
  nameJson  Json   // { ar: "العناية بالشعر", en: "Hair Care" }
  slug      String @unique
  iconUrl   String?
  imageUrl  String?
  sortOrder Int    @default(0)
  isActive  Boolean @default(true)
  parentId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  services Service[]

  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

model Service {
  id              Int      @id @default(autoincrement())
  categoryId      Int
  titleJson       Json     // { ar: "قص شعر", en: "Haircut" }
  descriptionJson Json?    // { ar: "...", en: "..." }
  basePrice       Decimal  @db.Decimal(10, 2)
  durationMin     Int      // Duration in minutes
  imageUrl        String?
  slug            String?   @unique
  isActive        Boolean  @default(true)
  isPopular       Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category          Category            @relation(fields: [categoryId], references: [id])
  variants          ServiceVariant[]
  servicesWithAddon ServiceAddon[] @relation("ServiceAddons")
  addonFor          ServiceAddon[] @relation("AddonServices")
  technicianServices TechnicianService[]
  bookings          Booking[]
  tags              ServiceTagAssignment[]
  wishlistItems     WishlistItem[]

  @@index([categoryId, isActive])
  @@index([basePrice])
  @@map("services")
}

model ServiceVariant {
  id             Int     @id @default(autoincrement())
  serviceId      Int
  nameJson       Json    // { ar: "طويل", en: "Long Hair" }
  priceDelta     Decimal @default(0) @db.Decimal(10, 2) // Additional price
  durationDelta  Int     @default(0) // Additional minutes
  isActive       Boolean @default(true)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_variants")
}

model ServiceAddon {
  id        Int     @id @default(autoincrement())
  serviceId Int
  addonId   Int
  isActive  Boolean @default(true)

  service Service @relation("ServiceAddons", fields: [serviceId], references: [id], onDelete: Cascade)
  addon   Service @relation("AddonServices", fields: [addonId], references: [id], onDelete: Cascade)

  @@unique([serviceId, addonId])
  @@index([serviceId])
  @@map("service_addons")
}

model ServiceTag {
  id       Int    @id @default(autoincrement())
  nameJson Json   // { ar: "مناسب للعرايس", en: "Bridal" }
  slug     String @unique

  assignments ServiceTagAssignment[]

  @@map("service_tags")
}

model ServiceTagAssignment {
  id        Int @id @default(autoincrement())
  serviceId Int
  tagId     Int

  service Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tag     ServiceTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([serviceId, tagId])
  @@map("service_tag_assignments")
}

// =============================================================================
// Technician ↔ Service Mapping
// =============================================================================

model TechnicianService {
  id           Int      @id @default(autoincrement())
  technicianId Int
  serviceId    Int
  customPrice  Decimal? @db.Decimal(10, 2) // Null = use base price
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  service    Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([technicianId, serviceId])
  @@index([technicianId])
  @@index([serviceId])
  @@map("technician_services")
}

// =============================================================================
// Availability & Booking
// =============================================================================

model AvailabilitySlot {
  id           Int      @id @default(autoincrement())
  technicianId Int
  startAt      DateTime
  endAt        DateTime
  isBooked     Boolean  @default(false)
  isAvailable  Boolean  @default(true) // Technician can mark as unavailable
  bookingId    Int?     @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  booking    Booking?   @relation("SlotBooking", fields: [bookingId], references: [id])

  @@index([technicianId, startAt, isBooked])
  @@index([technicianId, startAt, endAt])
  @@map("availability_slots")
}

model Booking {
  id                 Int           @id @default(autoincrement())
  bookingCode        String        @unique // Human-readable: GOB-XXXXXX
  customerId         Int
  technicianId       Int
  serviceId          Int
  variantId          Int?
  addressId          Int
  startAt            DateTime
  endAt              DateTime
  status             BookingStatus @default(REQUESTED)
  totalAmount        Decimal       @db.Decimal(10, 2)
  platformFee        Decimal       @db.Decimal(10, 2) @default(0)
  paymentFee         Decimal       @db.Decimal(10, 2) @default(0)
  cashHandlingFee    Decimal       @db.Decimal(10, 2) @default(0)
  providerRevealed   Boolean       @default(false)
  notes              String?
  waitlistTriggered  Boolean       @default(false)
  idempotencyKey     String?       @unique
  cancelledAt        DateTime?
  cancelReason       String?
  googleEventId      String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  customer   User              @relation("CustomerBookings", fields: [customerId], references: [id])
  technician User              @relation("TechnicianBookings", fields: [technicianId], references: [id])
  service    Service           @relation(fields: [serviceId], references: [id])
  address    Address           @relation(fields: [addressId], references: [id])
  slot       AvailabilitySlot? @relation("SlotBooking")
  payment    Payment?
  review     Review?
  dispute    Dispute?
  zatcaInvoice ZatcaInvoice?

  @@index([customerId, status, createdAt])
  @@index([technicianId, status, startAt])
  @@index([bookingCode])
  @@index([idempotencyKey])
  @@index([status, createdAt])
  @@map("bookings")
}

// =============================================================================
// Payments (PayFort / Amazon Payment Services)
// =============================================================================

model Payment {
  id            Int           @id @default(autoincrement())
  bookingId     Int           @unique
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("SAR")
  gatewayRef    String?       // PayFort transaction reference
  intent        PaymentIntent @default(AUTHORIZE)
  status        PaymentStatus @default(AUTHORIZED)
  commission    Decimal       @default(0) @db.Decimal(10, 2) // Gateway commission
  idempotencyKey String?      @unique
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([gatewayRef])
  @@index([status])
  @@index([bookingId])
  @@map("payments")
}

// =============================================================================
// Payouts (Technician Earnings)
// =============================================================================

model Payout {
  id           Int          @id @default(autoincrement())
  technicianId Int          // References User.id (technician's user ID)
  periodStart  DateTime
  periodEnd    DateTime
  amount       Decimal      @db.Decimal(10, 2)
  fee          Decimal      @default(0) @db.Decimal(10, 2)
  status       PayoutStatus @default(PENDING)
  reference    String?      // Bank transfer reference
  notes        String?
  processedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  technician User @relation(fields: [technicianId], references: [id])

  @@index([technicianId, status])
  @@index([periodStart, periodEnd])
  @@map("payouts")
}

// =============================================================================
// Reviews & Ratings
// =============================================================================

model Review {
  id        Int      @id @default(autoincrement())
  bookingId Int      @unique
  customerId Int
  rating    Int      // 1-5
  comment   String?
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer User    @relation("CustomerReviews", fields: [customerId], references: [id])

  @@index([customerId])
  @@map("reviews")
}

// =============================================================================
// Disputes
// =============================================================================

model Dispute {
  id          Int           @id @default(autoincrement())
  bookingId   Int           @unique
  raisedBy    Int           // User who raised the dispute
  reason      String
  description String?
  evidenceUrl String?       // S3 URL to evidence file
  status      DisputeStatus @default(OPEN)
  resolution  String?
  resolvedBy  Int?          // Admin who resolved it
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  booking     Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  raiser      User    @relation("DisputeRaisedBy", fields: [raisedBy], references: [id])
  resolver    User?   @relation("DisputeResolvedBy", fields: [resolvedBy], references: [id])

  @@index([status])
  @@index([raisedBy])
  @@map("disputes")
}

// =============================================================================
// Notifications
// =============================================================================

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // e.g., 'booking_created', 'payment_success', 'reminder'
  titleJson Json     // { ar: "...", en: "..." }
  bodyJson  Json     // { ar: "...", en: "..." }
  link      String?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  sentVia   String[] // ['email', 'sms', 'push', 'in_app']
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================================================
// Waitlist
// =============================================================================

model WaitlistEntry {
  id            Int            @id @default(autoincrement())
  customerId    Int
  technicianId  Int
  serviceId     Int?
  status        WaitlistStatus @default(WAITING)
  position      Int
  expiresAt     DateTime?
  notifiedAt    DateTime?
  claimedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  customer   User      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@unique([technicianId, customerId])
  @@index([technicianId, status])
  @@index([customerId])
  @@map("waitlist_entries")
}

// =============================================================================
// Terms & Compliance
// =============================================================================

model TermsAcceptance {
  id           Int      @id @default(autoincrement())
  userId       Int
  termsVersion String   // e.g., "v2.1"
  ipAddress    String
  userAgent    String?
  acceptedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, termsVersion])
  @@map("terms_acceptances")
}

// =============================================================================
// ZATCA E-Invoicing
// =============================================================================

model ZatcaInvoice {
  id                  Int         @id @default(autoincrement())
  bookingId           Int         @unique
  invoiceNumber       String      @unique // ZATCA-compliant format
  invoiceHash         String?     // Cryptographic hash
  cryptographicStamp  String?     // ZATCA signed stamp
  qrCode              String?     // Base64 encoded QR code
  status              ZatcaStatus @default(PENDING)
  reportedAt          DateTime?
  clearedAt           DateTime?
  errorMessage        String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([invoiceNumber])
  @@index([status])
  @@map("zatca_invoices")
}

// =============================================================================
// Audit Log (Admin Actions)
// =============================================================================

model AuditLog {
  id         Int      @id @default(autoincrement())
  adminId    Int
  action     String   // e.g., 'SUSPEND_USER', 'VERIFY_KYC', 'UPDATE_CATEGORY'
  targetType String   // e.g., 'User', 'Booking', 'Category'
  targetId   String   // ID of the affected record
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

// =============================================================================
// AI & Subscription Features
// =============================================================================

model AiSubscriptionPlan {
  id            Int    @id @default(autoincrement())
  nameJson      Json   // { ar: "الباقة الأساسية", en: "Basic Plan" }
  feature       AiFeature
  monthlyLimit  Int    // Max AI requests per month
  priceMonthly  Decimal @db.Decimal(10, 2)
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions CustomerAiSubscription[]

  @@map("ai_subscription_plans")
}

model CustomerAiSubscription {
  id         Int                @id @default(autoincrement())
  userId     Int                @unique
  planId     Int
  status     SubscriptionStatus @default(ACTIVE)
  startedAt  DateTime           @default(now())
  expiresAt  DateTime
  autoRenew  Boolean            @default(false)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  plan  AiSubscriptionPlan @relation(fields: [planId], references: [id])
  usage AiUsage[]

  @@index([userId, status])
  @@map("customer_ai_subscriptions")
}

model AiUsage {
  id             Int      @id @default(autoincrement())
  subscriptionId Int
  feature        AiFeature
  tokensUsed     Int      @default(0)
  requestCount   Int      @default(1)
  createdAt      DateTime @default(now())

  subscription CustomerAiSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
  @@map("ai_usage")
}

// =============================================================================
// AI Chatbot (Layla)
// =============================================================================

model ChatMessage {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int?     // Null if talking to AI chatbot
  content    String
  isAi       Boolean  @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())

  sender User @relation("SenderMessages", fields: [senderId], references: [id])

  @@index([senderId, createdAt])
  @@map("chat_messages")
}

// =============================================================================
// Onboarding Quiz & Recommendations
// =============================================================================

model CustomerQuizResponse {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  responses Json     // { "skin_type": "oily", "preferred_services": ["hair", "nails"] }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customer_quiz_responses")
}

model RecommendationFeedback {
  id              Int      @id @default(autoincrement())
  userId           Int
  recommendedItemType String // 'service' or 'technician'
  recommendedItemId Int
  feedback        String   // 'thumbs_up' or 'thumbs_down'
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@map("recommendation_feedback")
}

// =============================================================================
// Wishlist (Customer Saved Items)
// =============================================================================

model WishlistItem {
  id           Int      @id @default(autoincrement())
  userId       Int
  serviceId    Int?
  technicianId Int?
  createdAt    DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  service    Service?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  technician Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  @@unique([userId, serviceId])
  @@unique([userId, technicianId])
  @@index([userId])
  @@index([createdAt])
  @@map("wishlist_items")
}

// =============================================================================
// Saudi Cities Reference Data (for dropdowns, autocomplete)
// =============================================================================

model SaudiCity {
  id        Int    @id @default(autoincrement())
  nameAr    String
  nameEn    String
  regionAr  String
  regionEn  String
  isActive  Boolean @default(true)

  @@unique([nameAr, regionAr])
  @@index([nameAr])
  @@index([regionAr])
  @@map("saudi_cities")
}

// =============================================================================
// Beauty Streaks & Achievements (Gamification)
// =============================================================================

model Streak {
  id              Int      @id @default(autoincrement())
  customerId      Int      @unique
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastBookingDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer User @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model Achievement {
  id          Int    @id @default(autoincrement())
  key         String @unique   // e.g., 'first_booking', 'weekly_streak', 'five_bookings'
  nameJson    Json             // { ar: "أول حجز", en: "First Booking" }
  descriptionJson Json         // { ar: "أكملي حجزك الأول", en: "Complete your first booking" }
  iconUrl     String?
  rewardAmount Decimal @default(0) @db.Decimal(10, 2)

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            Int      @id @default(autoincrement())
  userId        Int
  achievementId Int
  awardedAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

// =============================================================================
// Referral Program
// =============================================================================

model Referral {
  id             Int      @id @default(autoincrement())
  referrerId     Int      // User who referred
  referredId     Int      // User who was referred (must complete first booking)
  referralCode   String   @unique // Unique code for sharing
  status         String   @default("PENDING") // PENDING, COMPLETED, EXPIRED
  rewardCredited Boolean  @default(false)
  referrerReward Decimal  @default(20) @db.Decimal(10, 2)
  referredReward Decimal  @default(20) @db.Decimal(10, 2)
  completedAt    DateTime?
  createdAt      DateTime @default(now())

  referrer User @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("ReferralsReceived", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([referredId])
  @@index([referralCode])
  @@map("referrals")
}

// =============================================================================
// Platform Configuration (Admin Settings)
// =============================================================================

model PlatformConfig {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  value        String
  description  String?
  updatedBy    Int
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@map("platform_configs")
}
