{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@galaxy/shared": ["../../packages/shared/src"],
      "@galaxy/api": ["../../packages/api/src"],
      "@galaxy/db": ["../../packages/db/src"]
    }
  }
}
