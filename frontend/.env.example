# =============================================================================
# Galaxy of Beauty - Frontend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# API Base URL
VITE_API_URL=http://localhost:4000/api

# WebSocket URL
VITE_WS_URL=http://localhost:4000

# App Settings
VITE_APP_NAME=Galaxy of Beauty
VITE_APP_NAME_AR=جالكسي بيوتي
VITE_DEFAULT_LANGUAGE=ar
VITE_SUPPORTED_LANGUAGES=ar,en

# Payment (PayFort)
VITE_PAYFORT_MERCHANT_ID=your_merchant_id
VITE_PAYFORT_SANDBOX=true

# Google (Calendar & Maps)
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key

# Sentry (Error tracking)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
